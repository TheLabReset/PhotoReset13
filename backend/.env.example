# Backend (Railway). Placeholders — NO valores reales. Se setean como variables
# de entorno del servicio en Railway; NUNCA se commitean.
PRINTER_KEY=cambia-esto
PANEL_PASSWORD=cambia-esto
FRONTEND_ORIGIN=https://tu-sitio.netlify.app
DATA_DIR=/data
# Railway inyecta PORT solo. Localmente puedes usar 8000.

# Opcionales (tienen defaults sensatos):
# PAPER_TOTAL=108           # capacidad del cartucho KP-108IN (papel+tinta), para el panel
# PAPER_LOW_THRESHOLD=10    # quedan <= esto -> el panel avisa "cambiar cartucho"
# PRINTING_TIMEOUT_S=180    # un 'printing' más viejo que esto vuelve a la cola
# AGENT_STALE_S=30          # sin heartbeat por más de esto = agente "sin señal"
